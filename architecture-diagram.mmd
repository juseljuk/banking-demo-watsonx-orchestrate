graph TB
    subgraph "Customer Interface"
        Customer[👤 Customer]
    end
    
    subgraph "watsonx Orchestrate Platform"
        Orchestrator[🎯 Banking Orchestrator Agent<br/>Primary Interface<br/>Authentication & Routing]
        
        subgraph "Specialist Agents"
            CustomerService[👔 Customer Service Agent<br/>Account Operations<br/>Balance, Transfers, History]
            FraudDetection[🔍 Fraud Detection Agent<br/>Risk Analysis<br/>Real-time Monitoring]
            LoanProcessing[💰 Loan Processing Agent<br/>Loan Applications<br/>Eligibility & Offers]
            ComplianceRisk[⚖️ Compliance & Risk Agent<br/>Regulatory Checks<br/>Audit & Compliance]
        end
        
        subgraph "Guardrails Layer"
            subgraph "Pre-Invoke Guardrails"
                TransactionLimit[💳 Transaction Limit<br/>Daily: £10k/£25k/£5k<br/>Single: £50k]
                FraudRules[🚨 Fraud Rules<br/>Risk Score 0-100<br/>Block if ≥91]
                LendingCompliance[📋 Lending Compliance<br/>FCA CONC 5.2A<br/>Credit/DTI/Income Checks]
            end
            
            subgraph "Post-Invoke Guardrails"
                PIIProtection[🔒 PII Protection<br/>Redacts: Accounts, NI,<br/>Emails, Phones, Cards]
            end
        end
        
        subgraph "Tools & Workflows"
            CoreBanking[🏦 Core Banking Toolkit<br/>MCP Server - 8 Tools<br/>Auth, Balance, Transfer, etc.]
            FraudTools[🔍 Fraud Detection Toolkit<br/>MCP Server - 8 Tools<br/>Risk Analysis, AML, etc.]
            LoanTools[💰 Loan Processing Toolkit<br/>MCP Server - 9 Tools<br/>Eligibility, Credit, Offers]
            LoanWorkflow[⚡ Loan Approval Workflow<br/>Agentic Workflow<br/>60% Faster Processing]
        end
        
        subgraph "Data Layer"
            DataFiles[(📁 JSON Data Files<br/>customers.json<br/>accounts.json<br/>transactions.json<br/>credit_reports.json<br/>loan_applications.json<br/>fraud_scenarios.json<br/>devices.json<br/>sessions.json)]
        end
    end
    
    Customer -->|Banking Requests| Orchestrator
    Orchestrator -->|Routes: Account Ops| CustomerService
    Orchestrator -->|Routes: Risk Analysis| FraudDetection
    Orchestrator -->|Routes: Loan Apps| LoanProcessing
    Orchestrator -->|Routes: Compliance| ComplianceRisk
    
    CustomerService -->|Pre-Check| TransactionLimit
    CustomerService -->|Pre-Check| FraudRules
    FraudDetection -->|Pre-Check| FraudRules
    LoanProcessing -->|Pre-Check| LendingCompliance
    
    CustomerService -->|Post-Check| PIIProtection
    FraudDetection -->|Post-Check| PIIProtection
    LoanProcessing -->|Post-Check| PIIProtection
    ComplianceRisk -->|Post-Check| PIIProtection
    Orchestrator -->|Post-Check| PIIProtection
    
    CustomerService -->|Uses Tools| CoreBanking
    FraudDetection -->|Uses Tools| FraudTools
    LoanProcessing -->|Uses Tools| LoanTools
    LoanProcessing -->|Uses Workflow| LoanWorkflow
    ComplianceRisk -->|Uses Tools| CoreBanking
    ComplianceRisk -->|Uses Tools| FraudTools
    Orchestrator -->|Auth Tools| CoreBanking
    
    CoreBanking -->|Read/Write| DataFiles
    FraudTools -->|Read| DataFiles
    LoanTools -->|Read| DataFiles
    LoanWorkflow -->|Orchestrates| LoanTools
    
